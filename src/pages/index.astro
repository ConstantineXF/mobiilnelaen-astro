---
// ПОЛНЫЙ КОД для файла: src/pages/index.astro
import { client as sanityClient } from '../lib/sanity';
import MainLayout from '../layouts/MainLayout.astro';
import Card from '../components/Card.astro';
import Hero from '../components/Hero.astro';
import DeviceBadge from '../components/DeviceBadge.astro';
import LoanFilter from '../components/LoanFilter.astro';
import FaqSection from '../components/FaqSection.astro';
import SmartCalculator from '../components/SmartCalculator.tsx';
import ApplicationForm from '../components/ApplicationForm.astro';
import SubscriptionForm from '../components/SubscriptionForm.astro';
import Testimonials from '../components/Testimonials.astro';
import LiveFeed from '../components/LiveFeed.astro';
import Stats from '../components/Stats.astro';
import TrustBadges from '../components/TrustBadges.astro';
import ApplySteps from '../components/ApplySteps.astro';
import MobileCta from '../components/MobileCta.astro';

const allOffers = await sanityClient.fetch(`*[_type == "loanOffer"]{_id, providerName, loanType, maxAmount, maxTerm, interestRate, "slug": slug.current, offerUrl} | order(providerName asc)`);
---

<MainLayout
  title="Mobiilne laen — Eesti laenude võrdlus | MobiilneLaen.ee"
  description="Mobiilne laen otse nutiseadmest: võrdle Eesti kiirlaene, väikelaene, krediidikontosid ja krediitkaarte ühel lehel. Vaata intresse, KKM-i ja tingimusi ning taotle telefonist."
>

  <Hero />
  <DeviceBadge />

  <div class="container mx-auto px-4 mt-6">
    <TrustBadges />
  </div>

  <div id="laenud" class="container mx-auto px-4 py-8 md:py-12">
    <LoanFilter />

    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

      {allOffers.map(offer => (
        <Card offerData={offer} />
      ))}
    </div>
  </div>

  <div class="container mx-auto px-4 pb-4">
    <ApplySteps />
  </div>


  <section class="py-16 bg-slate-100">
    <div class="container mx-auto px-4">

      <SmartCalculator client:load allOffers={allOffers} />
    </div>
  </section>
<LiveFeed />
<Testimonials />
  <FaqSection 
    title="Korduma kippuvad küsimused" 
    category="mobiilne-laen" 
  />

  <ApplicationForm />
  <SubscriptionForm />
<Stats />

  <MobileCta href="#laenud" label="Vaata pakkumisi" />
</MainLayout>