---
// Файл: src/pages/go/[slug].astro
// Финальная, исправленная версия
import { client as sanityClient } from '../../lib/sanity';

export async function getStaticPaths() {
  // Запрашиваем ТОЛЬКО слаг и URL для каждого оффера
  const offers = await sanityClient.fetch(`*[_type == "loanOffer" && defined(slug.current)]{"slug": slug.current, "url": offerUrl}`);

  return offers.map((offer: any) => {
    return {
      params: { slug: offer.slug }, // Например: { slug: 'credit24' }
      props: { destinationUrl: offer.url }, // Передаем реальный URL в пропсы
    };
  });
}

const { destinationUrl } = Astro.props;

// Если по какой-то причине URL не нашелся, перенаправляем на главную
if (!destinationUrl) {
  return Astro.redirect('/', 307);
}
---
<!doctype html>
<html lang="et">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="refresh" content={`0;url=${destinationUrl}`}>
    <title>Suuname edasi...</title>
    <meta name="robots" content="noindex, nofollow">
  </head>
  <body style="font-family: sans-serif; text-align: center; padding-top: 5rem;">
    <p>
      Palun oodake, suuname teid pakkumisele...<br>
      <a href={destinationUrl}>Vajuta siia, kui teid ei suunatud automaatselt edasi.</a>
    </p>
  </body>
</html>