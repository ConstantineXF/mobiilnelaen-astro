---
import { client as sanityClient } from '../lib/sanity';
import LoanLanding from '../components/LoanLanding.astro';
import content from '../data/loanTypes/krediidikonto';

const allOffers = await sanityClient.fetch(
  `*[_type == "loanOffer"]{_id, providerName, loanType, maxAmount, maxTerm, interestRate, "slug": slug.current, offerUrl} | order(providerName asc)`
);
const offers = allOffers.filter((o: any) => o.loanType === content.loanType);
---

<LoanLanding content={content} offers={offers} allOffers={allOffers} />
