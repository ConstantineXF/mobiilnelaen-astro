---
// Файл: src/pages/krediidikonto.astro
import { client as sanityClient } from '../lib/sanity';
import MainLayout from '../layouts/MainLayout.astro';
import Card from '../components/Card.astro';
import FaqSection from '../components/FaqSection.astro';
import ContentBlock from '../components/ContentBlock.astro';
import SmartCalculator from '../components/SmartCalculator.tsx';
import InteractiveCost from '../components/InteractiveCost.tsx';
import Voting from '../components/Voting.tsx';

const allOffers = await sanityClient.fetch(`*[_type == "loanOffer"]{_id, providerName, loanType, maxAmount, maxTerm, interestRate, "slug": slug.current, offerUrl} | order(providerName asc)`);
const pageOffers = allOffers.filter(offer => offer.loanType === 'krediidikonto');
---

<MainLayout title="Krediidikonto - Paindlik laenulimiit sinu tingimustel">
  <div class="container mx-auto px-4 py-8 md:py-12">
    <div class="text-center mb-12">
      <h1 class="text-4xl font-extrabold text-slate-800">Krediidikonto</h1>
      <p class="text-slate-500 mt-2">Sinu isiklik laenulimiit, mida saad kasutada igal ajal.</p>
    </div>

    {pageOffers.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {pageOffers.map(offer => <Card offerData={offer} />)}
      </div>
    ) : (
      <p class="text-center bg-blue-100 text-blue-800 p-4 rounded-md">Sellele tüübile vastavaid pakkumisi hetkel ei leitud.</p>
    )}
  </div>

  <ContentBlock title="Krediidikonto eelised">
    <p>Krediidikonto on paindlik alternatiiv tavalaenule. See toimib nagu virtuaalne krediitkaart, pakkudes sulle isiklikku laenulimiiti. Sa võid raha välja võtta just siis, kui seda vajad, ja tagasi maksta omas tempos. Intressi arvestatakse ainult kasutatud summalt, mis teeb sellest kuluefektiivse lahenduse ootamatuteks olukordadeks.</p>
  </ContentBlock>
<Voting client:load voteId="krediidikonto-votes" />
  <section class="py-16 bg-slate-100">
    <div class="container mx-auto px-4">
      <SmartCalculator client:load allOffers={allOffers} defaultCategory="krediidikonto" />
    </div>
  </section>

  <InteractiveCost client:load />

  <FaqSection 
    title="Korduma kippuvad küsimused krediidikonto kohta" 
    category="krediidikonto" 
  />
</MainLayout>