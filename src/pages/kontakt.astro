---
import MainLayout from '../layouts/MainLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const breadcrumbs = [
  { name: 'Avaleht', href: '/' },
  { name: 'Kontakt', href: '/kontakt' },
];
---

<MainLayout
  title="Kontakt | MobiilneLaen.ee"
  description="Võta MobiilneLaen.ee-ga ühendust: kirjuta meile e-kirja teel või täida kontaktivorm. Vastame tööpäeviti."
>
  <Breadcrumbs items={breadcrumbs} />

  <section class="container mx-auto px-4 py-10 max-w-3xl">
    <div class="text-center">
      <h1 class="text-3xl md:text-4xl font-extrabold text-slate-800">Kontakt</h1>
      <p class="text-slate-500 mt-3 max-w-xl mx-auto">
        Küsimused, ettepanekud või koostöö? Kirjuta meile — vastame esimesel võimalusel.
      </p>
    </div>

    <div class="mt-8 grid grid-cols-1 sm:grid-cols-3 gap-4">
      <a href="mailto:Info@mobiilnelaen.ee" class="flex flex-col items-center gap-2 bg-white border border-slate-200 rounded-xl p-5 text-center hover:border-cyan-300 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cyan-500"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        <span class="text-sm font-semibold text-slate-700">Info@mobiilnelaen.ee</span>
      </a>
      <div class="flex flex-col items-center gap-2 bg-white border border-slate-200 rounded-xl p-5 text-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cyan-500"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <span class="text-sm font-semibold text-slate-700">Tööaeg 24/7</span>
      </div>
      <div class="flex flex-col items-center gap-2 bg-white border border-slate-200 rounded-xl p-5 text-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cyan-500"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
        <span class="text-sm font-semibold text-slate-700">Tallinn, Eesti</span>
      </div>
    </div>

    <form id="contact-form" class="mt-8 bg-white border border-slate-200 rounded-xl shadow-sm p-6 md:p-8 space-y-5">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <div>
          <label for="c-name" class="block text-sm font-medium text-slate-700 mb-1">Nimi</label>
          <input id="c-name" name="name" type="text" required class="w-full p-3 border border-slate-300 rounded-md focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 focus:outline-none" />
        </div>
        <div>
          <label for="c-email" class="block text-sm font-medium text-slate-700 mb-1">E-post</label>
          <input id="c-email" name="email" type="email" required class="w-full p-3 border border-slate-300 rounded-md focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 focus:outline-none" />
        </div>
      </div>
      <div>
        <label for="c-message" class="block text-sm font-medium text-slate-700 mb-1">Sõnum</label>
        <textarea id="c-message" name="message" rows="5" required class="w-full p-3 border border-slate-300 rounded-md focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 focus:outline-none"></textarea>
      </div>
      {/* Honeypot против спама */}
      <input type="text" name="company" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />
      <label class="flex items-start gap-3">
        <input type="checkbox" required class="h-4 w-4 mt-0.5 rounded border-gray-300 text-cyan-600 focus:ring-cyan-500" />
        <span class="text-sm text-slate-600">
          Nõustun <a href="/privaatsuspoliitika" class="underline hover:text-cyan-600">privaatsuspoliitikaga</a>.
        </span>
      </label>
      <button type="submit" class="w-full bg-cyan-500 text-white font-bold py-3 rounded-lg hover:bg-cyan-600 transition-colors shadow-lg">
        Saada sõnum
      </button>
      <p data-form-status class="text-sm text-center hidden"></p>
    </form>
  </section>

  <script is:inline>
    (function () {
      var form = document.getElementById('contact-form');
      if (!form) return;
      var status = form.querySelector('[data-form-status]');
      var btn = form.querySelector('button[type="submit"]');

      form.addEventListener('submit', async function (e) {
        e.preventDefault();
        if (form.company && form.company.value) return; // honeypot
        btn.disabled = true;
        var original = btn.textContent;
        btn.textContent = 'Saadan…';
        status.className = 'text-sm text-center text-slate-500';
        status.textContent = '';

        try {
          var res = await fetch('/api/lead', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              formType: 'contact',
              name: form.name.value,
              email: form.email.value,
              message: form.message.value,
            }),
          });
          if (!res.ok) throw new Error('fail');
          form.reset();
          status.className = 'text-sm text-center text-emerald-600';
          status.textContent = 'Aitäh! Sõnum on saadetud, vastame esimesel võimalusel.';
        } catch (err) {
          status.className = 'text-sm text-center text-rose-600';
          status.textContent = 'Saatmine ebaõnnestus. Proovi uuesti või kirjuta Info@mobiilnelaen.ee.';
        } finally {
          btn.disabled = false;
          btn.textContent = original;
        }
      });
    })();
  </script>
</MainLayout>
