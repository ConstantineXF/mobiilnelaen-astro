---
// Файл: src/pages/krediidiliin.astro
import { client as sanityClient } from '../lib/sanity';
import MainLayout from '../layouts/MainLayout.astro';
import Card from '../components/Card.astro';
import FaqSection from '../components/FaqSection.astro';
import ContentBlock from '../components/ContentBlock.astro';
import SmartCalculator from '../components/SmartCalculator.tsx';
import InteractiveCost from '../components/InteractiveCost.tsx';
import Voting from '../components/Voting.tsx';

const allOffers = await sanityClient.fetch(`*[_type == "loanOffer"]{_id, providerName, loanType, maxAmount, maxTerm, interestRate, "slug": slug.current, offerUrl} | order(providerName asc)`);
const pageOffers = allOffers.filter(offer => ['krediidiliin', 'krediidilimiit'].includes(offer.loanType));
---

<MainLayout title="Krediidiliin - Paindlik laenulimiit ootamatusteks">
  <div class="container mx-auto px-4 py-8 md:py-12">
    <div class="text-center mb-12">
      <h1 class="text-4xl font-extrabold text-slate-800">Krediidiliin</h1>
      <p class="text-slate-500 mt-2">Paindlik lahendus ootamatuteks väljaminekuteks.</p>
    </div>

    {pageOffers.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {pageOffers.map(offer => <Card offerData={offer} />)}
      </div>
    ) : (
      <p class="text-center bg-blue-100 text-blue-800 p-4 rounded-md">Sellele tüübile vastavaid pakkumisi hetkel ei leitud.</p>
    )}
  </div>

  <ContentBlock title="Mis on krediidiliin?">
    <p>Krediidiliin on personaalne laenulimiit, mis on Sinu jaoks alati avatud. See annab Sulle vabaduse ja kindlustunde, et ootamatute kulutuste tekkimisel on Sul olemas finantsiline puhver. Erinevalt tavalisest laenust, ei pea Sa kogu summat korraga välja võtma ning intressi maksad vaid kasutatud osa pealt.</p>
  </ContentBlock>
<Voting client:load voteId="krediidiliin-votes" />
  <section class="py-16 bg-slate-100">
    <div class="container mx-auto px-4">
      <SmartCalculator client:load allOffers={allOffers} defaultCategory="krediidiliin" />
    </div>
  </section>

  <InteractiveCost client:load />

  <FaqSection 
    title="Korduma kippuvad küsimused krediidiliini kohta" 
    category="krediidiliin" 
  />
</MainLayout>