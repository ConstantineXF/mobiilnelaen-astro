---
// Файл: src/pages/autolaen.astro
import { client as sanityClient } from '../lib/sanity';
import MainLayout from '../layouts/MainLayout.astro';
import Card from '../components/Card.astro';
import FaqSection from '../components/FaqSection.astro';
import ContentBlock from '../components/ContentBlock.astro';
import SmartCalculator from '../components/SmartCalculator.tsx';
import InteractiveCost from '../components/InteractiveCost.tsx';
import Voting from '../components/Voting.tsx';

const allOffers = await sanityClient.fetch(`*[_type == "loanOffer"]{_id, providerName, loanType, maxAmount, maxTerm, interestRate, "slug": slug.current, offerUrl} | order(providerName asc)`);
const pageOffers = allOffers.filter(offer => offer.loanType === 'autolaen');
---

<MainLayout title="Autolaenud - Finantseeri oma uus auto targalt">
  <div class="container mx-auto px-4 py-8 md:py-12">
    <div class="text-center mb-12">
      <h1 class="text-4xl font-extrabold text-slate-800">Autolaen</h1>
      <p class="text-slate-500 mt-2">Võrdle pakkumisi ja leia parim lahendus oma uue auto soetamiseks.</p>
    </div>

    {pageOffers.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {pageOffers.map(offer => <Card offerData={offer} />)}
      </div>
    ) : (
      <p class="text-center bg-blue-100 text-blue-800 p-4 rounded-md">Sellele tüübile vastavaid laenupakkumisi hetkel ei leitud.</p>
    )}
  </div>

  <ContentBlock title="Milleks sobib autolaen?">
    <p>Autolaen on sihtotstarbeline laen uue või kasutatud sõiduki ostmiseks. Erinevalt liisingust saab laenu võtja kohe auto omanikuks. Paljud pakkujad ei nõua sissemakset ning pakuvad paindlikku laenuperioodi. See on ideaalne lahendus, kui soovid vabadust valida endale sobiv sõiduk ja kaskokindlustus.</p>
  </ContentBlock>
<Voting client:load voteId="autolaen-votes" />
  <section class="py-16 bg-slate-100">
    <div class="container mx-auto px-4">
      <SmartCalculator client:load allOffers={allOffers} defaultCategory="autolaen" />
    </div>
  </section>

  <InteractiveCost client:load />

  <FaqSection 
    title="Korduma kippuvad küsimused autolaenude kohta" 
    category="autolaen" 
  />
</MainLayout>