---
// Липкая нижняя CTA-панель для мобильных (lg:hidden).
interface Props {
  href?: string;
  label?: string;
}
const { href = '#laenud', label = 'Vaata pakkumisi' } = Astro.props as Props;
---

{/* Спейсер, чтобы фиксированная панель не перекрывала контент над футером */}
<div class="h-20 lg:hidden" aria-hidden="true"></div>

<div class="lg:hidden fixed inset-x-0 bottom-0 z-50 bg-white/95 backdrop-blur border-t border-slate-200 px-4 py-3 pb-[calc(0.75rem+env(safe-area-inset-bottom))]">
  <a
    href={href}
    class="flex items-center justify-center gap-2 w-full bg-cyan-500 hover:bg-cyan-600 text-white font-bold py-3 rounded-xl shadow-lg transition-colors"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="20" x="5" y="2" rx="2"/><path d="M12 18h.01"/></svg>
    {label}
  </a>
</div>
