---
import type { ConditionRow } from '../data/loanTypes/types';
interface Props {
  conditions: ConditionRow[];
  requirements: string[];
}
const { conditions, requirements } = Astro.props as Props;
---

<div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
  {/* Условия */}
  <div class="bg-white border border-slate-200 rounded-xl shadow-sm p-6">
    <h3 class="text-lg font-bold text-slate-800 mb-4">Tingimused</h3>
    <dl class="divide-y divide-slate-100">
      {
        conditions.map((row) => (
          <div class="flex items-center justify-between py-2.5 gap-4">
            <dt class="text-slate-500">{row.label}</dt>
            <dd class="font-semibold text-slate-800 text-right">{row.value}</dd>
          </div>
        ))
      }
    </dl>
  </div>

  {/* Требования */}
  <div class="bg-white border border-slate-200 rounded-xl shadow-sm p-6">
    <h3 class="text-lg font-bold text-slate-800 mb-4">Nõuded laenajale</h3>
    <ul class="space-y-3">
      {
        requirements.map((req) => (
          <li class="flex items-start gap-2.5 text-slate-700">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cyan-500 mt-0.5 shrink-0"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
            <span>{req}</span>
          </li>
        ))
      }
    </ul>
  </div>
</div>
