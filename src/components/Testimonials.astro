---
// Файл: src/components/Testimonials.astro
import { client as sanityClient } from '../lib/sanity';

// Запрашиваем 3 последних отзыва
const testimonials = await sanityClient.fetch(`*[_type == "testimonial"] | order(_createdAt desc)[0...3]`);

// Функция для отображения звезд рейтинга
function renderStars(rating: number) {
  let stars = '';
  for (let i = 0; i < 5; i++) {
    stars += i < rating ? '★' : '☆';
  }
  return stars;
}
---
<section class="bg-slate-50 py-16">
  <div class="container mx-auto px-4">
    <h2 class="text-3xl font-extrabold text-center mb-10">Meie klientide tagasiside</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {testimonials.map((testimonial: any) => (
        <div class="bg-white p-6 rounded-xl shadow-lg border border-slate-200">
          <div class="flex items-center mb-2">
            <span class="text-lg text-yellow-500">{renderStars(testimonial.rating)}</span>
          </div>
          <p class="text-slate-600 italic">"{testimonial.reviewText}"</p>
          <div class="mt-4 text-right">
            <p class="font-bold text-slate-800">{testimonial.authorName}</p>
            {testimonial.device && <p class="text-xs text-slate-500">Seade: {testimonial.device}</p>}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>