---
// Бейджи мобильной аутентификации EE — траст + тема «laen mobiilist».
interface Props {
  compact?: boolean;
}
const { compact = false } = Astro.props as Props;

const badges = [
  { label: 'Smart-ID' },
  { label: 'Mobiil-ID' },
  { label: 'ID-kaart' },
];
---

<div class={`flex flex-wrap items-center justify-center gap-2.5 ${compact ? '' : 'py-2'}`}>
  {!compact && (
    <span class="text-sm text-slate-500 mr-1">Turvaline tuvastamine:</span>
  )}
  {
    badges.map((b) => (
      <span class="inline-flex items-center gap-1.5 bg-white border border-slate-200 rounded-full px-3 py-1.5 text-sm font-semibold text-slate-700 shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-emerald-500"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>
        {b.label}
      </span>
    ))
  }
</div>
