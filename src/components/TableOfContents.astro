---
// Оглавление страницы. Открыто по умолчанию; на мобильном можно свернуть.
interface TocItem {
  id: string;
  label: string;
}
interface Props {
  items: TocItem[];
}
const { items } = Astro.props as Props;
---

<details open class="group bg-white border border-slate-200 rounded-xl shadow-sm overflow-hidden">
  <summary class="flex items-center justify-between cursor-pointer px-5 py-3.5 font-bold text-slate-800 select-none list-none">
    <span class="flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cyan-500"><line x1="8" x2="21" y1="6" y2="6"/><line x1="8" x2="21" y1="12" y2="12"/><line x1="8" x2="21" y1="18" y2="18"/><line x1="3" x2="3.01" y1="6" y2="6"/><line x1="3" x2="3.01" y1="12" y2="12"/><line x1="3" x2="3.01" y1="18" y2="18"/></svg>
      Sisukord
    </span>
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-400 transition-transform group-open:rotate-180"><path d="m6 9 6 6 6-6"/></svg>
  </summary>
  <nav class="px-5 pb-4 pt-1 border-t border-slate-100">
    <ol class="space-y-2 text-sm">
      {
        items.map((item, i) => (
          <li>
            <a href={`#${item.id}`} class="flex gap-2 text-slate-600 hover:text-cyan-600 transition-colors">
              <span class="text-slate-400 tabular-nums">{i + 1}.</span>
              <span>{item.label}</span>
            </a>
          </li>
        ))
      }
    </ol>
  </nav>
</details>
