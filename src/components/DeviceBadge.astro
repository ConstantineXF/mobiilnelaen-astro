---
// «Фишка»: определяем устройство посетителя и подчёркиваем, что заявку
// можно подать прямо с этого устройства (mobiilne laen).
---
<div class="container mx-auto px-4 -mt-4 flex justify-center">
  <div
    id="device-badge"
    class="hidden items-center gap-2.5 bg-white border border-cyan-100 shadow-sm rounded-full pl-3 pr-4 py-2 text-sm text-slate-700"
    role="status"
  >
    <span id="device-icon" class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-cyan-50 text-cyan-600">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/></svg>
    </span>
    <span id="device-text">Taotle laenu otse oma nutiseadmest</span>
  </div>
</div>

<script is:inline>
  (function () {
    function detect() {
      var badge = document.getElementById('device-badge');
      var text = document.getElementById('device-text');
      if (!badge || !text) return;

      var ua = navigator.userAgent || '';
      var isIPad = /iPad/.test(ua) || (/Macintosh/.test(ua) && navigator.maxTouchPoints > 1);
      var label = null;

      if (/iPhone|iPod/.test(ua)) label = 'iPhone';
      else if (isIPad) label = 'iPadi';
      else if (/Android/.test(ua)) label = /Mobile/.test(ua) ? 'Androidi' : 'Android-tahvli';
      else if (/Windows Phone/.test(ua)) label = 'Windows Phone’i';

      if (label) {
        text.textContent = 'Tuvastasime ' + label + ' — taotle laenu otse oma seadmest, paberivabalt.';
      } else {
        text.textContent = 'Kogu laenuprotsess käib mugavalt mobiilis — ava meie leht ka telefonis.';
      }

      badge.classList.remove('hidden');
      badge.classList.add('inline-flex');
    }

    detect();
    document.addEventListener('astro:page-load', detect);
  })();
</script>
