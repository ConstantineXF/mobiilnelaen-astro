---
import type { FaqEntry } from '../data/loanTypes/types';
interface Props {
  id?: string;
  title: string;
  items: FaqEntry[];
}
const { id = 'kkk', title, items } = Astro.props as Props;

// FAQPage микроразметка (JSON-LD)
const schema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((it) => ({
    '@type': 'Question',
    name: it.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: it.a.join('\n\n'),
    },
  })),
};
---

<section id={id} class="container mx-auto px-4 py-12 max-w-4xl scroll-mt-24">
  <h2 class="text-2xl md:text-3xl font-extrabold text-center text-slate-800 mb-8">{title}</h2>

  <div class="space-y-3">
    {
      items.map((it) => (
        <details class="group bg-white border border-slate-200 rounded-xl shadow-sm overflow-hidden">
          <summary class="flex items-center justify-between gap-4 cursor-pointer px-5 py-4 font-semibold text-slate-800 select-none list-none hover:bg-slate-50">
            <span>{it.q}</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cyan-500 shrink-0 transition-transform group-open:rotate-45"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
          </summary>
          <div class="px-5 pb-5 pt-0 text-slate-600 space-y-3 border-t border-slate-100">
            {it.a.map((p) => <p class="mt-3">{p}</p>)}
          </div>
        </details>
      ))
    }
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
