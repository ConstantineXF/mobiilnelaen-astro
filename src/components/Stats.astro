---
// Файл: src/components/Stats.astro

const statsData = [
  { label: 'Mobiilsed taotlused', value: '92%', color: 'bg-cyan-500' },
  { label: 'Heaks kiidetud', value: '85%', color: 'bg-green-500' },
  { label: 'Väljamakse 15 minutiga', value: '78%', color: 'bg-blue-500' },
];
---
<section class="bg-slate-100 py-16">
  <div class="container mx-auto px-4">
    <h2 class="text-3xl font-extrabold text-center mb-10">Statistika</h2>
    <div class="max-w-4xl mx-auto space-y-6">
      {statsData.map(stat => (
        <div>
          <div class="flex justify-between items-center mb-1">
            <span class="text-sm font-medium text-slate-700">{stat.label}</span>
            <span class="text-sm font-bold text-slate-900">{stat.value}</span>
          </div>
          <div class="w-full bg-slate-200 rounded-full h-4">
            <div class={stat.color + " h-4 rounded-full"} style={`width: ${stat.value}`}></div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>