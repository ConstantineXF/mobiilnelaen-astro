---
// «Taotle 2 minutiga» — визуализация мобильного процесса в 3 шага.
const steps = [
  {
    title: 'Vali pakkumine',
    text: 'Võrdle pakkujaid otse telefonis ja vali sobivaim laen.',
    icon: '<rect width="14" height="20" x="5" y="2" rx="2"/><path d="M12 18h.01"/>',
  },
  {
    title: 'Tuvasta end',
    text: 'Logi sisse turvaliselt Smart-ID või Mobiil-ID-ga, paberivabalt.',
    icon: '<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/>',
  },
  {
    title: 'Saa raha',
    text: 'Positiivse otsuse korral laekub raha kontole sageli samal päeval.',
    icon: '<circle cx="12" cy="12" r="10"/><path d="M14.5 9.5a3 3 0 0 0-5 2.5 3 3 0 0 0 5 2.5"/><path d="M8 12h4"/>',
  },
];
---

<section class="bg-slate-100 rounded-2xl px-5 py-8 md:px-8 md:py-10">
  <div class="text-center mb-8">
    <span class="inline-flex items-center gap-1.5 bg-cyan-50 text-cyan-700 text-sm font-semibold px-3 py-1 rounded-full">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      Taotle 2 minutiga
    </span>
    <h2 class="text-2xl md:text-3xl font-extrabold text-slate-800 mt-3">Laen otse mobiilist — 3 sammu</h2>
  </div>

  <ol class="grid grid-cols-1 sm:grid-cols-3 gap-5 md:gap-4">
    {
      steps.map((s, i) => (
        <li class="relative bg-white rounded-xl border border-slate-200 p-5 text-center">
          <span class="absolute -top-3 left-1/2 -translate-x-1/2 w-7 h-7 rounded-full bg-cyan-500 text-white text-sm font-bold flex items-center justify-center shadow">
            {i + 1}
          </span>
          <span class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-cyan-50 text-cyan-600 mt-2 mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={s.icon} />
          </span>
          <h3 class="font-bold text-slate-800">{s.title}</h3>
          <p class="text-sm text-slate-500 mt-1.5">{s.text}</p>
        </li>
      ))
    }
  </ol>
</section>
