---
interface Props {
  pros: string[];
  cons: string[];
}
const { pros, cons } = Astro.props as Props;
---

<div class="grid grid-cols-1 md:grid-cols-2 gap-5">
  {/* Плюсы */}
  <div class="bg-emerald-50 border border-emerald-100 rounded-xl p-6">
    <h3 class="flex items-center gap-2 text-lg font-bold text-emerald-800 mb-4">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
      Plussid
    </h3>
    <ul class="space-y-3">
      {
        pros.map((p) => (
          <li class="flex items-start gap-2.5 text-slate-700">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-emerald-500 mt-1 shrink-0"><path d="M20 6 9 17l-5-5"/></svg>
            <span>{p}</span>
          </li>
        ))
      }
    </ul>
  </div>

  {/* Минусы */}
  <div class="bg-rose-50 border border-rose-100 rounded-xl p-6">
    <h3 class="flex items-center gap-2 text-lg font-bold text-rose-800 mb-4">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      Miinused
    </h3>
    <ul class="space-y-3">
      {
        cons.map((c) => (
          <li class="flex items-start gap-2.5 text-slate-700">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-rose-400 mt-1 shrink-0"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
            <span>{c}</span>
          </li>
        ))
      }
    </ul>
  </div>
</div>
