---
import MainLayout from '../layouts/MainLayout.astro';
import Breadcrumbs from './Breadcrumbs.astro';
import TableOfContents from './TableOfContents.astro';
import ProsCons from './ProsCons.astro';
import LoanFacts from './LoanFacts.astro';
import LoanFaq from './LoanFaq.astro';
import Card from './Card.astro';
import TrustBadges from './TrustBadges.astro';
import ApplySteps from './ApplySteps.astro';
import MobileCta from './MobileCta.astro';
import SmartCalculator from './SmartCalculator.tsx';
import Voting from './Voting.tsx';
import type { LoanTypeContent } from '../data/loanTypes/types';

interface Props {
  content: LoanTypeContent;
  offers: any[];
  allOffers: any[];
}
const { content, offers, allOffers } = Astro.props as Props;

// Оглавление: фиксированные секции + динамические H2
const toc = [
  { id: 'pakkumised', label: 'Laenupakkumised' },
  { id: 'ulevaade', label: `Mis on ${content.navLabel.toLowerCase()}?` },
  { id: 'plussid-miinused', label: 'Plussid ja miinused' },
  { id: 'tingimused', label: 'Tingimused ja nõuded' },
  ...content.sections.map((s) => ({ id: s.id, label: s.title })),
  { id: 'kalkulaator', label: 'Laenukalkulaator' },
  { id: 'kkk', label: 'Korduma kippuvad küsimused' },
];

const breadcrumbs = [
  { name: 'Avaleht', href: '/' },
  { name: content.navLabel, href: `/${content.slug}` },
];
---

<MainLayout title={content.metaTitle} description={content.metaDescription}>
  <Breadcrumbs items={breadcrumbs} />

  {/* Заголовок — простой стиль (как было), без хвостов в H1 */}
  <div class="container mx-auto px-4 pt-6 md:pt-8 max-w-5xl text-center">
    <h1 class="text-4xl md:text-5xl font-extrabold text-slate-800">{content.navLabel}</h1>
    <p class="text-slate-500 mt-3 text-lg max-w-2xl mx-auto">{content.lead}</p>
    <div class="mt-5">
      <TrustBadges />
    </div>
  </div>

  <div class="container mx-auto px-4 py-8 md:py-12 max-w-5xl space-y-12">
    {/* SEO-вводный абзац сразу после H1 (прямые ВЧ-вхождения) */}
    <p class="text-base md:text-lg leading-relaxed text-slate-700 -mb-4" set:html={content.seoText} />

    {/* Оглавление */}
    <TableOfContents items={toc} />

    {/* Предложения партнёров */}
    <section id="pakkumised" class="scroll-mt-24">
      <h2 class="text-2xl md:text-3xl font-extrabold text-slate-800 mb-6">Laenupakkumised</h2>
      {
        offers.length > 0 ? (
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {offers.map((offer) => <Card offerData={offer} />)}
          </div>
        ) : (
          <p class="bg-blue-50 text-blue-800 p-4 rounded-lg">
            Sellele tüübile vastavaid laenupakkumisi hetkel ei leitud.
          </p>
        )
      }
    </section>

    {/* Как подать заявку — мобильный процесс */}
    <ApplySteps />

    {/* Обзор / Что это */}
    <section id="ulevaade" class="scroll-mt-24">
      <h2 class="text-2xl md:text-3xl font-extrabold text-slate-800 mb-4">
        Mis on {content.navLabel.toLowerCase()}?
      </h2>
      <div class="prose prose-slate max-w-none">
        {content.intro.map((p) => <p set:html={p} />)}
      </div>
    </section>

    {/* Плюсы и минусы */}
    <section id="plussid-miinused" class="scroll-mt-24">
      <h2 class="text-2xl md:text-3xl font-extrabold text-slate-800 mb-6">
        {content.navLabel} — plussid ja miinused
      </h2>
      <ProsCons pros={content.pros} cons={content.cons} />
    </section>

    {/* Условия и требования */}
    <section id="tingimused" class="scroll-mt-24">
      <h2 class="text-2xl md:text-3xl font-extrabold text-slate-800 mb-6">Tingimused ja nõuded</h2>
      <LoanFacts conditions={content.conditions} requirements={content.requirements} />
    </section>

    {/* Дополнительные H2-секции */}
    {
      content.sections.map((s) => (
        <section id={s.id} class="scroll-mt-24">
          <h2 class="text-2xl md:text-3xl font-extrabold text-slate-800 mb-4">{s.title}</h2>
          <div class="prose prose-slate max-w-none">
            {s.body.map((p) => <p set:html={p} />)}
          </div>
        </section>
      ))
    }

    {/* Калькулятор */}
    <section id="kalkulaator" class="scroll-mt-24">
      <h2 class="text-2xl md:text-3xl font-extrabold text-slate-800 mb-6">Laenukalkulaator</h2>
      <SmartCalculator client:visible allOffers={allOffers} defaultCategory={content.loanType} />
    </section>

    {/* Голосование */}
    <Voting client:visible voteId={`${content.slug}-votes`} />
  </div>

  {/* FAQ */}
  <LoanFaq title={`Korduma kippuvad küsimused — ${content.navLabel.toLowerCase()}`} items={content.faq} />

  {/* Липкий мобильный CTA */}
  <MobileCta href="#pakkumised" label="Vaata pakkumisi" />
</MainLayout>
