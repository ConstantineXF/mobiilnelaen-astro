---
// Хлебные крошки + BreadcrumbList JSON-LD (микроразметка). Центрированы, с иконками.
interface Crumb {
  name: string;
  href: string;
}
interface Props {
  items: Crumb[];
}
const { items } = Astro.props as Props;
const SITE_URL = 'https://mobiilnelaen.ee';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: items.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: c.name,
    item: new URL(c.href, SITE_URL).href,
  })),
};
---

<nav aria-label="Breadcrumb" class="container mx-auto px-4 pt-4">
  <ol class="flex flex-wrap items-center justify-center gap-x-1 gap-y-1 text-sm">
    {
      items.map((c, i) => (
        <li class="flex items-center">
          {i > 0 && (
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-300 mx-0.5 shrink-0"><path d="m9 18 6-6-6-6"/></svg>
          )}
          {i < items.length - 1 ? (
            <a
              href={c.href}
              class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-slate-500 hover:text-cyan-600 hover:bg-cyan-50 transition-colors"
            >
              {i === 0 && (
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
              )}
              <span>{c.name}</span>
            </a>
          ) : (
            <span class="inline-flex items-center px-2.5 py-1 rounded-full bg-slate-100 text-slate-700 font-medium" aria-current="page">
              {c.name}
            </span>
          )}
        </li>
      ))
    }
  </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
